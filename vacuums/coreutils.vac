voidname=coreutils
voidver=9.11
voidrev=1
voiddesc="GNU Core Utils"
voidlicense="GPL-2.0"
voidmaintainer="Alexandr Vod <a.e.vodolagin@yandex.ru>"
voidhome="https://ftp.gnu.org/gnu/coreutils"
voidurl="https://ftp.gnu.org/gnu/coreutils/coreutils-${voidver}.tar.xz"
voidsum=394024eda0a5955217ceda9cd1201e65dc8fa3aa29c2951135a49521d57c3cc3

build_void() {
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc
    make -j$(nproc)
}

install_void() {
    make DESTDIR=$DESTDIR install
}
